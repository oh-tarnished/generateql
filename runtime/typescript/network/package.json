{
	"name": "@machanirobotics/loom-network",
	"version": "1.0.0",
	"description": "Strongly typed transport client for HTTP, GraphQL, and WebSocket with unified Result envelopes.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/machanirobotics/loom.git",
		"directory": "typescript/network"
	},
	"main": "./index.ts",
	"module": "./index.ts",
	"types": "./index.ts",
	"exports": {
		".": {
			"types": "./index.ts",
			"import": "./index.ts",
			"default": "./index.ts"
		},
		"./types": "./types.ts"
	},
	"files": [
		"index.ts",
		"types.ts",
		"lib/**/*",
		"README.md"
	],
	"type": "module",
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"keywords": [
		"network",
		"http",
		"graphql",
		"websocket",
		"typescript",
		"zod",
		"apollo"
	],
	"scripts": {
		"build": "bun run typecheck",
		"docs": "typedoc --options typedoc.json",
		"docs:open": "npm run docs && node --input-type=module -e \"import open from 'open'; await open('docs/index.html');\"",
		"docs:json": "typedoc --options typedoc.json --json docs/api.json",
		"typecheck": "bunx tsc --noEmit",
		"test": "bun test",
		"prepublishOnly": "bun run typecheck"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/node": "^22.0.0",
		"open": "^10.1.0",
		"typedoc": "^0.28.18",
		"typescript": "^6.0.2"
	},
	"dependencies": {
		"@apollo/client": "^4.1.6",
		"graphql": "^16.13.2",
		"graphql-ws": "^6.0.8",
		"zod": "^4.3.6"
	}
}
